# Google Service Account (create at https://console.cloud.google.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"

# Google Drive folder ID (from folder URL: drive.google.com/drive/folders/<ID>)
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Optional: override default OpenAI models
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_FORMAT_MODEL=gpt-4o-mini

# Knowledge Hub password (shared with your team)
HUB_PASSWORD=your-secret-password

# Vercel Blob token (https://vercel.com/docs/storage/vercel-blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Secret for cron endpoint auth (any random string)
CRON_SECRET=your-random-secret
